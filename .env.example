# ProofMark API config
PORT=4000

# PostgreSQL connection string (Render provides this automatically via the blueprint).
DATABASE_URL=postgres://user:password@localhost:5432/proofmark

JWT_SECRET=
JWT_EXPIRE=7d

# Cloudinary (image storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# FPWM — the watermark engine
FPWM_BASE_URL=https://watermarking-engine.onrender.com
FPWM_API_KEY=
# qim-dct (live, CPU) or trustmark (neural; requires FPWM built with INSTALL_NEURAL=true)
FPWM_IMAGE_ENGINE=qim-dct

# CORS origin for the web UI
CLIENT_URL=http://localhost:5173
