# ProofMark API config
PORT=4000

# PostgreSQL connection string (Render provides this automatically via the blueprint).
DATABASE_URL=postgres://user:password@localhost:5432/proofmark

JWT_SECRET=
JWT_EXPIRE=7d

# Cloudinary (image storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# FPWM — the watermark engine
FPWM_BASE_URL=https://watermarking-engine.onrender.com
FPWM_API_KEY=
# qim-dct (live, CPU) or trustmark (neural; requires FPWM built with INSTALL_NEURAL=true)
FPWM_IMAGE_ENGINE=qim-dct
# qim-dct (standard CPU video) or videoseal (neural; separate worker recommended)
FPWM_VIDEO_ENGINE=qim-dct
# Keep aligned with the FPWM engine payload codec.
FPWM_MAX_PAYLOAD=268435455
FPWM_CAPABILITIES_TIMEOUT_MS=60000
FPWM_VIDEO_JOB_TIMEOUT_MS=120000
FPWM_VIDEO_STATUS_TIMEOUT_MS=60000
# Optional UI/API gate for legacy engines that do not expose /v1/image/capabilities.
# Keep false until TrustMark is installed and FPWM_BENCH_ENGINE=trustmark image gates pass.
FPWM_TRUSTMARK_ENABLED=false

# Video uploads are stored first, then processed asynchronously by FPWM.
MAX_VIDEO_UPLOAD_MB=250
MAX_VERIFY_VIDEO_UPLOAD_MB=250

# Web tracker (reverse-image search). Without a key, the tracker is disabled.
SEARCH_PROVIDER=google-vision
GOOGLE_VISION_API_KEY=
SCAN_CRON=0 3 * * *

# CORS origin for the web UI
CLIENT_URL=http://localhost:5173
